# chrome-plane server 环境变量模板
#
# 用法：复制为 .env.development（开发，npm run dev）或 .env.production（生产，npm start）。
# env.ts 会按 NODE_ENV 加载对应文件，两份文件互不干扰。
# NODE_ENV 本身由 npm 脚本经 cross-env 注入，通常无需手填。
#
# 真实的 .env.* 文件已被 .gitignore 忽略；本模板只含占位符，可安全入库。

# ===== 运行环境 =====
HOST=127.0.0.1            # dev 建议 127.0.0.1（仅本机）；prod 可 0.0.0.0（务必配合鉴权）
PORT=8787

# ===== Plane =====
PLANE_API_TOKEN=plane_api_xxxxxxxxxxxxxxxx
# 自托管填主域名（如 https://support.max-optics.com）；plane.so 官方填 https://api.plane.so
PLANE_BASE_URL=https://support.max-optics.com

# ===== Playwright 图片下载（Bearer Token 失效时的回退登录方案）=====
PLAYWRIGHT_PLANE_EMAIL=your@email.com
PLAYWRIGHT_PLANE_PASSWORD=yourpassword
PLAYWRIGHT_PLANE_INSTANCE_URL=https://support.max-optics.com
PLAYWRIGHT_HEADLESS=false   # dev 可 false 便于调试；prod 建议 true

# ===== Claude Agent SDK（经 anthropic 兼容协议）=====
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxx
ANTHROPIC_BASE_URL=http://10.10.10.87:3000
ANTHROPIC_MODEL=glm-5.2
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.2
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2
ANTHROPIC_REASONING_MODEL=glm-5.2
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000

# ===== 本地代码仓库（Agent 修改代码用；不配则只做静态分析）=====
ENABLE_SKILLS=true
LOCAL_CODE_ROOT=C:\mo-project\web-gui
