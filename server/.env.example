# Plane API Token（在 Plane 个人设置 → API Tokens 创建）
PLANE_API_TOKEN=plane_api_xxx

# Plane API Base URL
# - 云端：https://api.plane.so
# - 自部署：https://your-plane-host
PLANE_BASE_URL=https://api.plane.so

# ============ Claude Agent SDK 鉴权 ============
# 方式 A：官方 Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx
#
# 方式 B：通过 MiniMax 等第三方 Anthropic 兼容网关
ANTHROPIC_AUTH_TOKEN=sk-cp-xxxx
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M2.7
ANTHROPIC_REASONING_MODEL=MiniMax-M2.7
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# 可选 MiniMax 额外变量
# MINIMAX_API_HOST=https://api.minimaxi.com
# MINIMAX_API_KEY=sk-cp-xxxx

# 可选：本地代码仓库根目录，配置后 Claude 可用 Read/Glob/Grep 工具引用本地代码
# LOCAL_CODE_ROOT=/Users/lsj/Desktop/project/your-repo

# 服务监听端口
PORT=8787
