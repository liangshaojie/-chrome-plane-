{
  "manifest_version": 3,
  "name": "Plane WorkItem Analyzer",
  "version": "0.4.0",
  "description": "用 Claude Agent SDK 分析 Plane 工作项（Bug / 需求）",
  "permissions": ["sidePanel", "activeTab", "tabs", "storage", "cookies"],
  "host_permissions": [
    "https://*.plane.so/*",
    "https://*.max-optics.com/*",
    "http://localhost:8787/*"
  ],
  "optional_host_permissions": [
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.plane.so/*", "https://*.max-optics.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "分析当前 Plane WorkItem"
  }
}
